---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'tech'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// 按 subcategory 分组 (保持时间倒序)
const grouped = new Map<string, typeof posts>();
for (const p of posts) {
  const key = p.data.subcategory || '未分类';
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(p);
}

// 子分类显示顺序: 5 个固定 + 任何出现过的未分类
const order = ['项目实战', '运维工具', 'AI 笔记', '前端全栈', '学习路线'];
const sortedKeys = Array.from(grouped.keys()).sort((a, b) => {
  const ai = order.indexOf(a);
  const bi = order.indexOf(b);
  if (ai === -1 && bi === -1) return a.localeCompare(b);
  if (ai === -1) return 1;
  if (bi === -1) return -1;
  return ai - bi;
});

// 子分类 anchor slug
function subcategorySlug(s: string): string {
  let h = 2166136261;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return 'sub-' + (h >>> 0).toString(36);
}

function formatDate(d: Date) {
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${d.getFullYear()}.${m}.${day}`;
}
---
<BaseLayout title="技术笔记 · 鹏飞日记" description="前后端、工具使用、AI 折腾笔记。" wide>
  <header style="margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px dashed var(--border);">
    <p style="color: var(--accent); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; margin: 0 0 0.8rem; display: flex; align-items: center; gap: 0.5rem;">
      <Icon name="sparkle" size={12} color="var(--accent)" />
      Category
    </p>
    <h1 style="font-family: var(--font-serif); font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 700; line-height: 1.2; margin: 0 0 0.8rem; letter-spacing: -0.02em;">
      <span style="background: var(--gradient); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;">技术</span>笔记
    </h1>
    <p style="color: var(--text-dim); font-size: 1.05rem; margin: 0;">共 <span style="color: var(--accent); font-weight: 600;">{posts.length}</span> 篇 · 5 个子分类</p>
  </header>

  <!-- 顶部子分类导航 (锚点跳转) -->
  <nav style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2.5rem; padding: 0.8rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);" aria-label="子分类导航">
    {sortedKeys.map((key) => (
      <a
        href={`#${subcategorySlug(key)}`}
        style="font-size: 0.8rem; padding: 0.35em 0.9em; border-radius: 100px; background: var(--bg-elev); color: var(--text-dim); border: 1px solid var(--border); text-decoration: none; font-weight: 500; transition: all var(--transition);"
        onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'; this.style.background='var(--accent-soft)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-dim)'; this.style.background='var(--bg-elev)'"
      >
        {key} <span style="color: var(--text-mute); font-weight: 400; font-size: 0.75em;">{grouped.get(key)!.length}</span>
      </a>
    ))}
  </nav>

  {posts.length === 0 ? (
    <p style="color: var(--text-dim); padding: 2rem 0;">还没写技术笔记呢。</p>
  ) : (
    <div style="display: grid; gap: 3rem;">
      {sortedKeys.map((key) => {
        const list = grouped.get(key)!;
        return (
          <section id={subcategorySlug(key)} style="scroll-margin-top: 6rem;">
            <h2 style="font-family: var(--font-serif); font-size: 1.4rem; font-weight: 700; margin: 0 0 1.2rem; padding-bottom: 0.6rem; border-bottom: 1px dashed var(--border); color: var(--text); display: flex; align-items: baseline; gap: 0.6rem;">
              <span>{key}</span>
              <span style="color: var(--text-mute); font-size: 0.8rem; font-weight: 400; font-family: var(--font-mono);">({list.length})</span>
            </h2>
            <ul style="list-style: none; padding: 0; display: grid; gap: 0.8rem;">
              {list.map((post) => (
                <li>
                  <a
                    href={`/blog/${post.id}/`}
                    style="display: block; background: var(--bg-card); border: 1px solid var(--border); border-left: 3px solid var(--border); border-radius: var(--radius); padding: 1.1rem 1.4rem; transition: all var(--transition); text-decoration: none;"
                    onmouseover="this.style.borderColor='var(--accent)'; this.style.borderLeftColor='var(--accent)'; this.style.transform='translateX(4px)'; this.style.boxShadow='var(--shadow)'; this.style.background='var(--bg-card-hover)'"
                    onmouseout="this.style.borderColor='var(--border)'; this.style.borderLeftColor='var(--border)'; this.style.transform=''; this.style.boxShadow=''; this.style.background='var(--bg-card)'"
                  >
                    <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.4rem; flex-wrap: wrap;">
                      <time datetime={post.data.pubDate.toISOString()} style="color: var(--text-mute); font-size: 0.8rem; font-family: var(--font-mono);">
                        {formatDate(post.data.pubDate)}
                      </time>
                      {post.data.tags.length > 0 && (
                        <span style="color: var(--text-mute); font-size: 0.8rem;">
                          {post.data.tags.slice(0, 3).map((t) => `#${t}`).join(' ')}
                        </span>
                      )}
                    </div>
                    <h3 style="font-family: var(--font-serif); font-size: 1.15rem; font-weight: 700; line-height: 1.35; color: var(--text); margin: 0 0 0.4rem;">
                      {post.data.title}
                    </h3>
                    {post.data.description && (
                      <p style="color: var(--text-dim); font-size: 0.9rem; line-height: 1.55; margin: 0;">
                        {post.data.description}
                      </p>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        );
      })}
    </div>
  )}
</BaseLayout>
