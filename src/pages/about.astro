---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Giscus from '../components/Giscus.astro';

const aboutCards = [
  {
    icon: 'briefcase',
    title: '工作',
    desc: '操作系统适配测试工程师, 专注硬件/驱动/软件兼容性测试工作。热爱技术, 关注互联网发展趋势。',
  },
  {
    icon: 'coffee',
    title: '生活',
    desc: '业余时间探索各种轻创业项目, 喜欢尝试新鲜事物。相信执行比点子更重要。',
  },
  {
    icon: 'target',
    title: '目标',
    desc: '寻找并实践可复制可执行的轻创业项目, 实现副业收入多元化, 持续积累可复利的产品。',
  },
  {
    icon: 'map-pin',
    title: '位置',
    desc: '长沙岳麓区, 欢迎交流互联网创业心得。',
  },
];

const projects = [
  {
    color: 'linear-gradient(135deg, #3b82f6 0%, #1e40af 100%)',
    icon: 'target',
    tag: 'AI Agent',
    title: 'Hermes Agent',
    desc: '自建的多 Agent 调度平台, 集成飞书/微信/IM 通道、技能管理、模型路由和定时任务。',
    url: 'https://hermes.imoons.cn',
  },
  {
    color: 'linear-gradient(135deg, #10b981 0%, #047857 100%)',
    icon: 'recycle',
    tag: '回收',
    title: '旧衣回收',
    desc: '对接线下回收点的旧衣分拣调度系统, 自动推单 + 状态跟踪 + 跨城调度。',
    url: 'https://sujh.net',
  },
  {
    color: 'linear-gradient(135deg, #ef4444 0%, #b91c1c 100%)',
    icon: 'gift',
    tag: '礼品',
    title: '灵渠圈',
    desc: '积分/任务/兑换一体化平台, 面向私域社群做用户活跃和裂变活动。',
    url: 'https://lingququan.imoons.cn',
  },
  {
    color: 'linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%)',
    icon: 'book-open',
    tag: '基金',
    title: '基金助手',
    desc: '全平台基金持仓统一管理, 收益分析 + 持仓汇总 + 跨平台对账, 一次登录全掌握。',
    url: 'https://fund.imoons.cn',
  },
  {
    color: 'linear-gradient(135deg, #f59e0b 0%, #d97706 100%)',
    icon: 'pen-tool',
    tag: '量化',
    title: 'A 股量化',
    desc: '本地化量化研究 + 选股 + 回测, 内置多策略 (MACD/KDJ/布林/均线量能) 跑历史。',
    url: 'https://quant.imoons.cn',
  },
  {
    color: 'linear-gradient(135deg, #ec4899 0%, #be185d 100%)',
    icon: 'sparkles',
    tag: '副业',
    title: '月光小站',
    desc: '副业项目集合主站, 把平时折腾的小工具/小产品都集中展示, 一个入口看全。',
    url: 'https://moonlight.imoons.cn',
  },
];
---
<BaseLayout title="关于 · 鹏飞日记" description="鹏飞日记 的个人介绍、做过的项目和联系方式。" wide>
  <article>
    <!-- ========== Hero ========== -->
    <section style="padding: 1rem 0 3rem;">
      <p style="color: var(--accent); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; margin: 0 0 1rem; display: flex; align-items: center; gap: 0.5rem;">
        <Icon name="sparkle" size={14} color="var(--accent)" />
        互联网创业者 · 折腾爱好者
      </p>
      <h1 style="font-family: var(--font-serif); font-size: clamp(2.2rem, 6vw, 3.4rem); font-weight: 700; line-height: 1.15; margin: 0 0 1.2rem; letter-spacing: -0.02em;">
        在<span style="background: var(--gradient); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;">长沙</span><br />
        做点<span style="background: var(--gradient); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;">有意思</span>的事情
      </h1>
      <p style="color: var(--text-dim); font-size: 1.05rem; line-height: 1.7; max-width: 560px; margin: 0 0 1.8rem;">
        操作系统适配测试工程师, 业余时间探索各种轻创业项目。相信低成本、可执行的副业, 才是普通人最好的选择。
      </p>
      <div style="display: flex; gap: 0.7rem; flex-wrap: wrap; margin-bottom: 2.5rem;">
        <a href="#projects" style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.65em 1.4em; background: var(--text); color: var(--bg); border-radius: 8px; font-size: 0.95rem; font-weight: 600; text-decoration: none; transition: all var(--transition);"
           onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='var(--shadow-lg)'"
           onmouseout="this.style.transform=''; this.style.boxShadow=''">
          看看我的项目 →
        </a>
        <a href="#contact" style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.65em 1.4em; background: transparent; border: 1px solid var(--border); border-radius: 8px; font-size: 0.95rem; font-weight: 500; color: var(--text); text-decoration: none; transition: all var(--transition);"
           onmouseover="this.style.borderColor='var(--accent)'; this.style.transform='translateY(-2px)'"
           onmouseout="this.style.borderColor='var(--border)'; this.style.transform=''">
          联系我
        </a>
      </div>
      <!-- 数据指标 -->
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; padding: 1.5rem 0; border-top: 1px solid var(--border-soft); border-bottom: 1px solid var(--border-soft); max-width: 480px;">
        <div>
          <div style="font-family: var(--font-serif); font-size: 2rem; font-weight: 700; color: var(--text); line-height: 1;">4+</div>
          <div style="color: var(--text-dim); font-size: 0.85rem; margin-top: 0.3rem;">副业项目</div>
        </div>
        <div>
          <div style="font-family: var(--font-serif); font-size: 2rem; font-weight: 700; color: var(--text); line-height: 1;">3年</div>
          <div style="color: var(--text-dim); font-size: 0.85rem; margin-top: 0.3rem;">互联网探索</div>
        </div>
        <div>
          <div style="font-family: var(--font-serif); font-size: 2rem; font-weight: 700; color: var(--text); line-height: 1;">∞</div>
          <div style="color: var(--text-dim); font-size: 0.85rem; margin-top: 0.3rem;">折腾精神</div>
        </div>
      </div>
    </section>

    <hr />

    <!-- ========== 01 / ABOUT ========== -->
    <section id="about" style="padding: 2rem 0 3rem;">
      <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 2rem; align-items: start; margin-bottom: 2rem;">
        <div>
          <p style="color: var(--text-mute); font-size: 0.85rem; font-weight: 500; letter-spacing: 0.1em; margin: 0 0 0.6rem; font-family: var(--font-mono);">01 / ABOUT</p>
          <h2 style="font-family: var(--font-serif); font-size: 2rem; font-weight: 700; margin: 0; line-height: 1.2;">关于我</h2>
        </div>
        <p style="color: var(--text-dim); font-size: 1.02rem; line-height: 1.7; margin: 0;">
          白天上班, 业余折腾。一个相信「副业是普通人第二收入曲线」的普通互联网人。
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem;">
        {aboutCards.map((card) => (
          <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.4rem; transition: all var(--transition);"
               onmouseover="this.style.borderColor='var(--accent)'; this.style.transform='translateY(-3px)'; this.style.boxShadow='var(--shadow)'"
               onmouseout="this.style.borderColor='var(--border)'; this.style.transform=''; this.style.boxShadow=''">
            <div style="width: 40px; height: 40px; border-radius: 8px; background: var(--accent-soft); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; color: var(--accent);">
              <Icon name={card.icon} size={22} />
            </div>
            <h3 style="font-family: var(--font-serif); font-size: 1.1rem; font-weight: 700; margin: 0 0 0.5rem; color: var(--text);">{card.title}</h3>
            <p style="color: var(--text-dim); font-size: 0.88rem; line-height: 1.6; margin: 0;">{card.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <!-- ========== 02 / PROJECTS ========== -->
    <section id="projects" style="padding: 2rem 0 3rem;">
      <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 2rem; align-items: start; margin-bottom: 2rem;">
        <div>
          <p style="color: var(--text-mute); font-size: 0.85rem; font-weight: 500; letter-spacing: 0.1em; margin: 0 0 0.6rem; font-family: var(--font-mono);">02 / PROJECTS</p>
          <h2 style="font-family: var(--font-serif); font-size: 2rem; font-weight: 700; margin: 0; line-height: 1.2;">做过的事</h2>
        </div>
        <p style="color: var(--text-dim); font-size: 1.02rem; line-height: 1.7; margin: 0;">
          目前跑过的几个项目。低成本启动, 可兼职操作, 门槛不高。
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem;">
        {projects.map((p) => (
          <a
            href={p.url}
            style="display: block; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; text-decoration: none; transition: all var(--transition);"
            onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='var(--shadow-lg)'; this.style.borderColor='transparent'"
            onmouseout="this.style.transform=''; this.style.boxShadow=''; this.style.borderColor='var(--border)'"
          >
            <!-- 渐变色顶部 -->
            <div style={`background: ${p.color}; height: 100px; display: flex; align-items: center; justify-content: center; color: white; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.1));`}>
              <Icon name={p.icon} size={42} color="#fff" />
            </div>
            <div style="padding: 1.2rem 1.4rem;">
              <span style="display: inline-block; font-size: 0.7rem; padding: 0.15em 0.6em; border-radius: 4px; background: var(--bg-elev); border: 1px solid var(--border); color: var(--text-dim); font-weight: 500; margin-bottom: 0.5rem;">
                {p.tag}
              </span>
              <h3 style="font-family: var(--font-serif); font-size: 1.1rem; font-weight: 700; color: var(--text); margin: 0.4rem 0 0.4rem; line-height: 1.3;">{p.title}</h3>
              <p style="color: var(--text-dim); font-size: 0.88rem; line-height: 1.55; margin: 0;">{p.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <hr />

    <!-- ========== 03 / CONTACT ========== -->
    <section id="contact" style="padding: 2rem 0 1rem;">
      <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 2rem; align-items: start; margin-bottom: 2rem;">
        <div>
          <p style="color: var(--text-mute); font-size: 0.85rem; font-weight: 500; letter-spacing: 0.1em; margin: 0 0 0.6rem; font-family: var(--font-mono);">03 / CONTACT</p>
          <h2 style="font-family: var(--font-serif); font-size: 2rem; font-weight: 700; margin: 0; line-height: 1.2;">联系我</h2>
        </div>
        <p style="color: var(--text-dim); font-size: 1.02rem; line-height: 1.7; margin: 0;">
          想聊点副业项目、互联网创业心得, 或者只是想认识一下, 都可以找我。
        </p>
      </div>
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2.5rem 2rem; text-align: center;">
        <p style="color: var(--text-dim); font-size: 0.95rem; margin: 0 0 1rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
          <Icon name="send" size={16} color="var(--text-dim)" />
          邮箱 · 微信 · 飞书
        </p>
        <div style="display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin-top: 1.2rem;">
          <a href="mailto:buer@imoons.cn" style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5em 1.2em; background: var(--bg-elev); border: 1px solid var(--border); border-radius: 100px; color: var(--text); font-size: 0.9rem; text-decoration: none; transition: all var(--transition);"
             onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'"
             onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text)'">
            <Icon name="mail" size={14} color="currentColor" />
            buer@imoons.cn
          </a>
          <a href="/blog/" style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5em 1.2em; background: var(--bg-elev); border: 1px solid var(--border); border-radius: 100px; color: var(--text); font-size: 0.9rem; text-decoration: none; transition: all var(--transition);"
             onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'"
             onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text)'">
            <Icon name="book-open" size={14} color="currentColor" />
            看博客
          </a>
        </div>
        <p style="color: var(--text-mute); font-size: 0.8rem; margin: 1.5rem 0 0;">
          扫码加我微信 · 请备注「<strong>副业</strong>」我才知道你是从主页来的
        </p>
      </div>
    </section>

    <Giscus />
  </article>
</BaseLayout>
