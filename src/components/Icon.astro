---
// 集中式 SVG 图标库 - 自写 path, 仿 Lucide 风格
// 用法: <Icon name="search" size={16} />

interface Props {
  name: string;
  size?: number;
  class?: string;
  color?: string;
  strokeWidth?: number;
}

const { name, size = 18, class: className = '', color = 'currentColor', strokeWidth = 1.5 } = Astro.props;

// 所有图标统一 24x24 viewBox, stroke-linecap=round, stroke-linejoin=round
const paths: Record<string, string> = {
  // 装饰类
  'sparkle': '<path d="M12 2 L13.5 8.5 L20 10 L13.5 11.5 L12 18 L10.5 11.5 L4 10 L10.5 8.5 Z"/><path d="M19 16 L19.7 18 L21.5 18.7 L19.7 19.4 L19 21 L18.3 19.4 L16.5 18.7 L18.3 18 Z"/>',

  // 导航/操作
  'search': '<circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>',
  'menu': '<path d="M3 6h18M3 12h18M3 18h18"/>',
  'close': '<path d="M18 6 6 18 M6 6l12 12"/>',
  'loader': '<path d="M21 12a9 9 0 1 1-6.219-8.56"/>',
  'info': '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>',
  'arrow-right': '<path d="M5 12h14 M12 5l7 7-7 7"/>',
  'arrow-left': '<path d="M19 12H5 M12 19l-7-7 7-7"/>',
  'corner-down-left': '<path d="m20 4-7 7-7-7 M20 12H4"/>',
  'external-link': '<path d="M15 3h6v6 M10 14 21 3 M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>',

  // 主题
  'moon': '<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>',
  'sun': '<circle cx="12" cy="12" r="4"/><path d="M12 2v2 M12 20v2 M4.9 4.9l1.4 1.4 M17.7 17.7l1.4 1.4 M2 12h2 M20 12h2 M4.9 19.1l1.4-1.4 M17.7 6.3l1.4-1.4"/>',
  'chevron-down': '<path d="m6 9 6 6 6-6"/>',

  // 状态
  'smile-plus': '<path d="M22 11v1a10 10 0 1 1-9-10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><path d="M9 9h.01 M15 9h.01"/>', // 简化版
  'frown': '<circle cx="12" cy="12" r="10"/><path d="M16 16s-1.5-2-4-2-4 2-4 2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>',

  // 评论
  'message-circle': '<path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.7a8.4 8.4 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.4 8.4 0 0 1 3.8-.9h.5a8.5 8.5 0 0 1 8 8z"/>',

  // 联系人/邮件
  'mail': '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/>',
  'send': '<path d="m22 2-7 20-4-9-9-4z"/><path d="M22 2 11 13"/>',
  'map-pin': '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/>',

  // 业务/职业
  'briefcase': '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
  'coffee': '<path d="M17 8h1a4 4 0 0 1 0 8h-1 M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z M6 2v3 M10 2v3 M14 2v3"/>',
  'target': '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  'pen-tool': '<path d="m12 19 7-7 3 3-7 7-3-3z M18 13l-1.5-7.5L2 2l3.5 14.5L13 18z M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/>',

  // 项目/创作
  'package': '<path d="m7.5 4.27 9 5.15 M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5 M12 22V12"/>',
  'recycle': '<path d="M7 19H4.815a1.83 1.83 0 0 1-1.57-.881 1.785 1.785 0 0 1-.004-1.784L7.196 9.5 M11 19l8.196-9.196 M16.804 4.815a1.83 1.83 0 0 1 1.57.881 1.785 1.785 0 0 1 .004 1.784L16.804 9.5 M3 12.196V8.815a1.83 1.83 0 0 1 .879-1.575 1.78 1.78 0 0 1 1.6-.003L7 9 M9 3.196l3.105 3.105a1.83 1.83 0 0 1 .003 1.578L9 11"/>',
  'gift': '<polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>',
  'book-open': '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  'palette': '<circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>',
  'sparkles': '<path d="M12 3l1.9 5.6a2 2 0 0 0 1.3 1.3L20.8 12l-5.6 1.9a2 2 0 0 0-1.3 1.3L12 20.8l-1.9-5.6a2 2 0 0 0-1.3-1.3L3.2 12l5.6-1.9a2 2 0 0 0 1.3-1.3z M5 3v4 M19 17v4 M3 5h4 M17 19h4"/>',
};

// 自闭合图标(用 path 即可)
const iconSvg = paths[name] || paths['sparkle'];

// 如果包含 fill="currentColor"(palette), 用 fill 模式;否则用 stroke 模式
const useFill = name === 'palette';
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={useFill ? color : 'none'}
  stroke={useFill ? 'none' : color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  style="display: inline-block; vertical-align: middle; flex-shrink: 0;"
  aria-hidden="true"
>
  <Fragment set:html={iconSvg} />
</svg>
