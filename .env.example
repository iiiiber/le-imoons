# =====================================================
# Giscus 评论配置
# =====================================================
# 后端仓库（已建好）：https://github.com/iiiiber/blog-comments
# 30 秒开通：https://giscus.app/zh-CN  →  选 iiiiber/blog-comments
#
# 开通后把 giscus.app 给你的 4 个值粘到 .env 对应行（去掉行首 #）

PUBLIC_GISCUS_REPO=iiiiber/blog-comments
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=General
PUBLIC_GISCUS_CATEGORY_ID=
